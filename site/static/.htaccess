# CloseProtectionHire.com - canonical host + transport enforcement.
# Deployed from site/static/.htaccess to public_html/.htaccess on Hostinger.
# Canonical host is https://closeprotectionhire.com/ (non-www), matching baseURL.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS. The X-Forwarded-Proto check prevents a redirect loop when
    # Hostinger terminates SSL upstream and forwards plain HTTP internally.
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Force non-www (redirect www -> apex).
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
</IfModule>

# Low-risk hardening headers.
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
